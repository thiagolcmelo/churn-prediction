# Virtual environment
.env/
env/
.venv/
venv/

# Python cache — auto-generated compiled bytecode, never commit
__pycache__/
*.pyc
*.pyo

# Raw data — large files, often private, downloaded separately
data/raw/

# Trained model binaries — large files, regenerated by training
models/*.pt
models/*.joblib

# MLflow tracking directory — experiment logs, can be large
mlruns/

# Jupyter notebook checkpoints — auto-saved backups, clutter the repo
.ipynb_checkpoints/

# IDE settings — personal editor configuration
.vscode/
.idea/

# Distribution artifacts — generated by pip/build
*.egg-info/
dist/
build/